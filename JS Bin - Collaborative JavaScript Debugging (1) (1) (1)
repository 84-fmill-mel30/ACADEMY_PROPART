@charset "utf-8";

@import url("https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Roboto:wght@300;400;700;900&display=swap");

body { font-family: Roboto, sans-serif; background-color: rgb(5, 8, 15); color: rgb(240, 246, 252); overflow-x: hidden; }

.font-tech { font-family: Orbitron, sans-serif; }

.hoja-pdf { background: white; color: black; width: 100%; max-width: 900px; min-height: 1100px; box-shadow: rgba(6, 182, 212, 0.3) 0px 0px 50px; margin: 20px auto; padding: 45px; position: relative; }

.neon-border { border: 2px solid rgb(6, 182, 212); box-shadow: rgba(6, 182, 212, 0.3) 0px 0px 20px; }

.btn-ui { background: rgb(30, 41, 59); border: 1px solid rgb(51, 65, 85); padding: 8px 16px; font-size: 11px; font-weight: 800; border-radius: 6px; transition: 0.3s; color: white; text-transform: uppercase; }

.btn-active { box-shadow: rgba(29, 78, 216, 0.5) 0px 0px 15px; background: rgb(29, 78, 216) !important; border-color: rgb(96, 165, 250) !important; }

.mic-active { animation: 1s ease 0s infinite normal none running pulse; color: rgb(255, 0, 0) !important; }

@keyframes pulse { 
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

@media print {
  .no-print { display: none !important; }
  .hoja-pdf { box-shadow: none; margin: 0px; width: 100%; }
}
